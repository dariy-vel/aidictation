# Copy this file to local.properties and fill in your API credentials
# Do NOT commit local.properties to version control

# Android SDK location
sdk.dir=/path/to/Android/Sdk

# Transcription API Configuration
TRANSCRIPTION_API_KEY=your_openai_or_groq_api_key_here

# Optional: override the default provider (OPENAI or GROQ). Defaults to GROQ.
# DEFAULT_TRANSCRIPTION_PROVIDER=GROQ

# Optional: override the default model for the selected provider.
# OPENAI default: whisper-1
# GROQ default:   whisper-large-v3-turbo
# TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# LLM API Configuration (used for post-processing, commands, and suggestions)
GROQ_API_KEY=your_groq_api_key_here

# Optional: override the default provider (OPENAI or GROQ). Defaults to GROQ.
# DEFAULT_POSTPROCESSING_PROVIDER=GROQ

# Optional: override the default model for the selected provider.
# OPENAI default: gpt-4o-mini
# GROQ default:   openai/gpt-oss-20b
# GROQ_MODEL=openai/gpt-oss-20b
